store violet_pattern at (5, 6, 1) colour VIOLET;
store violet_pattern at (6, 5, 1) colour VIOLET;
store violet_pattern at (6, 6, 1) colour VIOLET;
store violet_pattern at (7, 5, 1) colour VIOLET;
store violet_pattern at (7, 6, 1) colour VIOLET;

var blue_pattern = 77777;
store blue_pattern at (1, 8, 3) colour BLUE;
store blue_pattern at (2, 8, 3) colour BLUE;
store blue_pattern at (1, 9, 3) colour BLUE;
store blue_pattern at (2, 9, 3) colour BLUE;

var green_pattern = 66666;
