var large_number = 1234567;
store large_number at (5, 5, 5) colour GREEN;
store large_number at (5, 5, 5) colour UV;
store large_number at (5, 5, 5) colour BLUE;
store large_number at (5, 5, 5) colour RED;

load verification from (5, 5, 5) colour GREEN;
print verification;
